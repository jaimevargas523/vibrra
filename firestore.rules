rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Usuarios (clientes) ───────────────────────────────────────────────
    match /Usuarios/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !("saldo" in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
        && !("saldo" in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Clientes ──────────────────────────────────────────────────────────
    match /Clientes/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid
        && !("saldo" in request.resource.data.diff(resource.data).affectedKeys())
        && !("bonos_canciones" in request.resource.data.diff(resource.data).affectedKeys())
        && !("bonos_conexiones" in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Anfitriones ─────────────────────────────────────────────────────────
    // Financial fields are only writable by Cloud Functions (Admin SDK).
    // Client writes must not touch: recaudo_mes, comisiones_mes,
    // participacion_mes, bono_arranque_saldo, bono_arranque_usado,
    // liquidacion_estado, liquidacion_deuda, suscripcion_activa.
    match /Anfitriones/{uid} {
      function financialFieldsUnchanged() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return !("recaudo_mes" in changed)
            && !("comisiones_mes" in changed)
            && !("participacion_mes" in changed)
            && !("bono_arranque_saldo" in changed)
            && !("bono_arranque_usado" in changed)
            && !("liquidacion_estado" in changed)
            && !("liquidacion_deuda" in changed)
            && !("suscripcion_activa" in changed);
      }

      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid
        && !("recaudo_mes" in request.resource.data)
        && !("comisiones_mes" in request.resource.data)
        && !("participacion_mes" in request.resource.data);
      allow update: if request.auth != null && request.auth.uid == uid
        && financialFieldsUnchanged();
    }

    // ── Movimientos ─────────────────────────────────────────────────────────
    match /Movimientos/{docId} {
      allow read: if request.auth != null
        && resource.data.anfitrion_id == request.auth.uid;
    }

    // ── Negocios ────────────────────────────────────────────────────────────
    match /Negocios/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && resource == null || resource.data.owner_uid == request.auth.uid;
    }

    // ── Sesiones ────────────────────────────────────────────────────────────
    match /Sesiones/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Cola ─────────────────────────────────────────────────────────────────
    match /Cola/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Pujas ────────────────────────────────────────────────────────────────
    match /Pujas/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Transacciones ────────────────────────────────────────────────────────
    match /Transacciones/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ── Retiros ──────────────────────────────────────────────────────────────
    match /Retiros/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ── Configuracion (read-only) ────────────────────────────────────────────
    match /Configuracion/{docId} {
      allow read: if true;
    }

    // ── QR Login tokens ──────────────────────────────────────────────────────
    match /qr_login_tokens/{tokenId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
